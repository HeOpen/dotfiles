{
  "reload_style_on_change": true,
  "layer": "top", // Waybar position (top|bottom|left|right)
  "spacing": 10, // Space between modules
  "mode": "dock",
  "height": 0,
  "width": 0,

  "margin-top": 5,
  "margin-left": 10,
  "margin-right": 10,

  "modules-left": [
    "custom/fast-fetch",
    "hyprland/workspaces",
    "custom/separator",
    "custom/weather",
    "custom/separator",
    "hyprland/window",
    "custom/notification",
  ],
  "modules-center": ["clock"],
  "modules-right": [
    "mpris",
    "custom/separator",
    "cpu",
    "memory",
    "custom/nvidia",
    "disk",
    "temperature",
    "hyprland/language",
    "network",
    "pulseaudio",
    "custom/microphone",
    "battery",
    "bluetooth",
    "backlight",
    "custom/power",
  ],

  //Clock and calendar
  "clock": {
    "locale": "ru_RU.UTF-8",
    "format": "{:%A %R\n  %d.%m.%Y}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>",
      },
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "tz_up",
      "on-scroll-down": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down",
    },
  },
  //Battery
  "battery": {
    "states": {
      "good": 99,
      "warning": 50,
      "critical": 20,
    },
    //"bat":"BAT1",
    "format": "{icon}{capacity}%",
    "format-charging": "’ĆĪ {capacity}%",
    "format-plugged": "¾░ó¤ {capacity}%",
    "format-discharging": "¾▒¤ż {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["¾░ó£", "¾░éå", "¾░óØ", "¾░éŖ", "¾░éģ "],
  },
  //Sound
  "pulseaudio": {
    "format": "{icon}{volume}% {format_source} ",
    "format-bluetooth": "{icon}{volume}%",
    "format-muted": "Ņ¼ż ",
    "format-icons": {
      "headphone": "’Ćź ",
      "hands-free": "’ŖŻ ",
      "headset": "’Ćź",
      "phone": "’éĢ",
      "portable": "’éĢ",
      "car": "’å╣",
      "default": ["’Ć¦ ", "’Ć©  "],
    },
    "format-source": "’ä░ {volume}%",
    "format-source-muted": "’ä▒",
    "scroll-step": 1,
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
  },
  //Bluetooth
  "bluetooth": {
    "format-on": "’Ŗō ",
    "format-disabled": "¾░é»",
    "tooltip": "Bluetooth",
    "on-click": "blueman-manager",
    "return-type": "json",
  },
  //Wifi
  "network": {
    "format-wifi": "’ć½ ",
    "format-ethernet": "¾░łĆ ",
    "format-disconnected": "Ņ¼ü ",
    "tooltip-format-disconnected": "Desconectado",
    "tooltip-format-wifi": "{essid}({signalStrength}%) ’ć½ ",
    "tooltip-format-ethernet": "{ifname} ­¤¢¦ ",
    "on-click": "kitty nmtui",
  },
  //Brightness
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-alt-click": "click-right",
    "format-alt": "{icon} {percent}%",
    "format-icons": ["¾░ā× ", "¾░ā¤ ", "¾░āĀ "],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
    "tooltip": false,
  },
  //Power
  "custom/power": {
    "format": "’Ćæ ",
    "on-click": "wlogout --buttons-per-row 4 --margin-top 500 --margin-bottom 500 --margin-left 500 --margin-right 500 ",
    "tooltip": false,
  },
  //Workspaces
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "’äæ ",
      "default": "’Æ¬ ",
      "empty": "Ņ«Ŗ",
    },
    "persistent-workspaces": {
      "*": [1, 2, 3, 4, 5, 6],
    },
  },
  //Keyboard layout
  //Alt+Shift to switch between keyboard layouts
  "hyprland/language": {
    "format": "{}",
    "format-en": "EN",
    "format-es": "ES",
    "tooltip": true,
    "tooltip-format": "Alt + Shift",
  },
  //Power
  "custom/fast-fetch": {
    "format": " ¾░Żć ",
    "on-click": "vicinae toggle",
    "on-click-right": "kitty --hold fastfetch",
    "tooltip": false,
  },
  "cpu": {
    "format": "{usage}% ’Æ╝ ",
    "tooltip": true,
    "tooltip-format": "Uso de CPU: {usage}%\nN├║cleos: {cores}",
    "on-click": "kitty --hold btop",
  },
  "memory": {
    "format": "{}% Ņ┐ģ ",
    "tooltip": true,
    "tooltip-format": "RAM en uso: {used} / {total} ({percentage}%)",
  },
  "disk": {
    "format": "{percentage_free}% ’éĀ ",
    "tooltip": true,
    "tooltip-format": "Espacio libre: {free} / {total} ({percentage_free}%)",
  },
  "temperature": {
    "format": "{temperatureC}┬░C {icon}",
    "tooltip": true,
    "tooltip-format": "Temperatura actual: {temperatureC}┬░C\n > 80┬░C = ¾░Üī",
    "format-icons": ["’ŗē"],
  },
  "custom/weather": {
    "exec": "curl 'https://wttr.in/?format=1'",
    "interval": 3600,
    "format": "{}",
    "tooltip": true,
    "on-click": "kitty --hold curl 'https://wttr.in'",
    "on-click-right": "xdg-open https://wttr.in/",
  },
  "custom/nvidia": {
    "interval": 4,
    "return-type": "json",
    "exec": "/home/coruja/dotfiles/scripts/nvidia.sh",
    "format": "<span size='x-large' rise='-2500'>¾░ó«</span>{text}",
    "tooltip": "true",
    "tooltip-format": "{alt}",
  },
  "mpris": {
    "format": "   {player_icon}  {status_icon} <i>{title} - {artist}</i>",
    "player": "playerctld",
    "max-length": 100,
    "on-click": "playerctl previous",
    "on-click-middle": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "format-paused": "   {player_icon} {status_icon} {artist} - {title}",
    "player-icons": {
      "default": "’Ćü",
      "spotify": "’å╝ ",
      "mpv": "’Ćü ",
    },
    "status-icons": {
      "paused": " ’üŗ",
      "playing": "’üī",
    },
  },
  "custom/separator": {
    "format": " | ",
    "tooltip": false,
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "¾░éÜ <span foreground='red'><sup>’æä</sup></span>",
      "none": "¾░éÜ ",
      "dnd-notification": "¾░éø <span foreground='red'><sup>’æä</sup></span>",
      "dnd-none": "¾░éø ",
      "inhibited-notification": "¾░éÜ <span foreground='red'><sup>’æä</sup></span>",
      "inhibited-none": "¾░éÜ ",
      "dnd-inhibited-notification": "¾░éø <span foreground='red'><sup>’æä</sup></span>",
      "dnd-inhibited-none": "¾░éø ",
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
  },
}
